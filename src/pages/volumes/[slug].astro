---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import VisualCredit from '../../components/VisualCredit.astro';
import { assetPath, visibleArticles } from '../../lib/kotatsu';

export async function getStaticPaths() {
  const volumes = await getCollection('volumes');
  return volumes.map((volume) => ({ params: { slug: volume.slug }, props: { volume } }));
}

const { volume } = Astro.props;
const articles = visibleArticles(await getCollection('articles')).filter((article) => article.data.volume === volume.slug);
const hasPublishedArticles = articles.some((article) => article.data.status === 'published');
const volumeIsPlanning = volume.data.status === 'planning' && !hasPublishedArticles;
const leadArticle = articles.find((article) => article.data.status === 'published') ?? articles[0];
const heroImage = volume.data.coverImage || leadArticle?.data.heroImage || '/logo.svg';
const heroAlt = volume.data.coverAlt || leadArticle?.data.heroAlt || 'KOTATSU';
const heroVisual = volume.data.coverImage ? volume.data.visual : (leadArticle?.data.visual ?? volume.data.visual);
---
<BaseLayout title={volume.data.title} description={volume.data.subtitle} image={assetPath(volumeIsPlanning ? '/logo.svg' : heroImage)}>
  <main>
    <section class:list={['volume-hero', { 'volume-hero--planning': volumeIsPlanning }]}>
      {volumeIsPlanning ? (
        <div class="volume-hero__mark">
          <img src={assetPath('/logo.svg')} alt="KOTATSU" />
        </div>
      ) : (
        <div class="volume-hero__image">
          <img src={assetPath(heroImage)} alt={heroAlt} />
        </div>
      )}
      <div class="volume-hero__copy">
        <p class="volume-label">Vol. {String(volume.data.number).padStart(3, '0')}</p>
        <h1>{volume.data.title}</h1>
        <p>{volume.data.subtitle}</p>
        {volumeIsPlanning ? (
          <p class="planning-status">このVol.は準備中です。記事ラインナップと公開日は、決まり次第お知らせします。</p>
        ) : (
          <VisualCredit mode={heroVisual.mode} intent={heroVisual.intent} />
        )}
      </div>
    </section>
    {volumeIsPlanning ? (
      <section class="section planning-panel" aria-label="Editorial planning status">
        <p class="eyebrow">PREPARING</p>
        <h2>記事ラインナップは準備中です</h2>
        <p>公開前の記事ページにはリンクしません。公開予定が決まり次第、目次に掲載します。</p>
      </section>
    ) : (
      <section class="section">
        <div class="article-grid article-grid--volume">
          {articles.map((article) => <ArticleCard article={article} />)}
        </div>
      </section>
    )}
  </main>
</BaseLayout>