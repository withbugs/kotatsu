---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import ArticleCard from '../components/ArticleCard.astro';
import VisualCredit from '../components/VisualCredit.astro';
import { assetPath, categories, visibleArticles } from '../lib/kotatsu';

const volumes = await getCollection('volumes');
const volume = volumes.find((entry) => entry.slug === 'vol-001') ?? volumes[0];
const volumeIsPlanning = volume.data.status === 'planning';
const allArticles = volumeIsPlanning ? [] : visibleArticles(await getCollection('articles'));
const volumeArticles = allArticles.filter((article) => article.data.volume === volume.slug);
const leadArticle = volumeArticles.find((article) => article.data.kind === 'cover-story') ?? volumeArticles[0];
const secondaryArticles = volumeArticles.filter((article) => article.id !== leadArticle?.id);
---
<BaseLayout title="KOTATSU" description={volume.data.subtitle} image={volumeIsPlanning ? assetPath('/logo.svg') : assetPath(volume.data.coverImage)}>
  <main>
    <section class:list={['home-hero', { 'home-hero--planning': volumeIsPlanning }]}>
      {volumeIsPlanning ? (
        <div class="home-hero__paper"></div>
      ) : (
        <>
          <img src={assetPath(volume.data.coverImage)} alt={volume.data.coverAlt} />
          <div class="home-hero__shade"></div>
        </>
      )}
      <div class="home-hero__copy">
        <p class="volume-label">Vol. {String(volume.data.number).padStart(3, '0')}</p>
        <img class="home-hero__logo" src={assetPath('/logo.svg')} alt="KOTATSU" />
        <p class="home-hero__volume">{volume.data.title}</p>
        <p class="home-hero__lead">{volume.data.subtitle}</p>
        <a class:list={['text-link', { 'text-link--light': !volumeIsPlanning }]} href={assetPath(`/volumes/${volume.slug}/`)}>
          {volumeIsPlanning ? '準備状況を見る' : 'Read this volume'}
        </a>
      </div>
      {!volumeIsPlanning && <VisualCredit mode={volume.data.visual.mode} intent={volume.data.visual.intent} />}
    </section>

    <section class="section section--intro">
      <div class="section__head">
        <p class="eyebrow">MONTHLY VOLUME</p>
        <h2>{volume.data.title}</h2>
      </div>
      <p class="intro-copy">
        {volumeIsPlanning
          ? '最初のVol.は、テーマと記事構成を丁寧に準備しています。公開日が決まり次第、このページでお知らせします。'
          : '大人の日常を、少しだけ洒落たものにする。服、喫茶店、街歩き、道具、音楽をひとつのVol.として編んでいきます。'}
      </p>
    </section>

    {volumeIsPlanning ? (
      <section class="section planning-panel" aria-label="Editorial planning status">
        <p class="eyebrow">PREPARING</p>
        <h2>準備中</h2>
        <p>記事ラインナップと公開日は、決まり次第このページでお知らせします。</p>
      </section>
    ) : (
      <>
        {leadArticle && (
          <section class="section feature-band">
            <ArticleCard article={leadArticle} emphasis />
          </section>
        )}

        <section class="section">
          <div class="section__head section__head--row">
            <div>
              <p class="eyebrow">LATEST</p>
              <h2>創刊Vol.の記事</h2>
            </div>
            <a class="text-link" href={assetPath(`/volumes/${volume.slug}/`)}>View all</a>
          </div>
          <div class="article-grid">
            {secondaryArticles.map((article) => <ArticleCard article={article} />)}
          </div>
        </section>
      </>
    )}

    <section class="section category-strip" aria-label="Categories">
      {categories.map((category) => (
        <a href={assetPath(`/${category.slug}/`)}>
          <span>{category.label}</span>
          <small>{category.description}</small>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>