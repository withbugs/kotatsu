---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';
import VisualCredit from '../../components/VisualCredit.astro';
import { assetPath, visibleArticles } from '../../lib/kotatsu';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({ params: { slug: issue.slug }, props: { issue } }));
}

const { issue } = Astro.props;
const issueIsPlanning = issue.data.status === 'planning';
const articles = issueIsPlanning
  ? []
  : visibleArticles(await getCollection('articles')).filter((article) => article.data.issue === issue.slug);
---
<BaseLayout title={issue.data.title} description={issue.data.subtitle} image={issueIsPlanning ? assetPath('/logo.svg') : assetPath(issue.data.coverImage)}>
  <main>
    <section class:list={['issue-hero', { 'issue-hero--planning': issueIsPlanning }]}>
      {issueIsPlanning ? (
        <div class="issue-hero__mark">
          <img src={assetPath('/logo.svg')} alt="KOTATSU" />
        </div>
      ) : (
        <div class="issue-hero__image">
          <img src={assetPath(issue.data.coverImage)} alt={issue.data.coverAlt} />
        </div>
      )}
      <div class="issue-hero__copy">
        <p class="issue-label">ISSUE {String(issue.data.number).padStart(3, '0')}</p>
        <h1>{issue.data.title}</h1>
        <p>{issue.data.subtitle}</p>
        {issueIsPlanning ? (
          <p class="planning-status">この号は準備中です。記事ラインナップと公開日は、決まり次第お知らせします。</p>
        ) : (
          <VisualCredit mode={issue.data.visual.mode} intent={issue.data.visual.intent} />
        )}
      </div>
    </section>
    {issueIsPlanning ? (
      <section class="section planning-panel" aria-label="Editorial planning status">
        <p class="eyebrow">PREPARING</p>
        <h2>記事ラインナップは準備中です</h2>
        <p>公開前の記事ページにはリンクしません。公開予定が決まり次第、目次に掲載します。</p>
      </section>
    ) : (
      <section class="section">
        <div class="article-grid article-grid--issue">
          {articles.map((article) => <ArticleCard article={article} />)}
        </div>
      </section>
    )}
  </main>
</BaseLayout>

